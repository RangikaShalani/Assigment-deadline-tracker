{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://127.0.0.1:4173/"
      ],
      "numberOfRuns": 1,
      "startServerCommand": "npx vite preview --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "http://127.0.0.1:4173",
      "settings": {
        "chromeFlags": "--no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 300
          }
        ],
        "categories:performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
